{
  "name": "oscilloscope-simulator",
  "version": "1.0.0",
  "description": "示波器仿真系统",
  "main": "electron-main.js",
  "homepage": "./",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "set NODE_ENV=production && webpack --config webpack.config.js --mode production --optimization-minimize && node packaging/optimize-build.js",
    "desktop:dev": "node scripts/desktop-dev.js",
    "desktop:build": "npm run build && node packaging/build.js"
  },
  "build": {
    "appId": "com.oscilloscope.simulator",
    "productName": "示波器仿真系统",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "docs/**/*",
      "assets/**/*",
      "!docs/**/*.map"
    ],
    "extraResources": [
      {
        "from": "docs",
        "to": "docs"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/x64/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "dat.gui": "^0.7.9",
    "three": "^0.177.0",
    "vue": "^2.7.16"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "electron": "^28.0.0",
    "electron-builder": "26.8.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.4",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "wait-on": "^7.2.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
